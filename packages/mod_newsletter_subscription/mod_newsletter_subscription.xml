<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade">
    <name>MOD_NEWSLETTER_SUBSCRIPTION</name>
    <author>Bogdan Shumylo</author>
    <authorEmail>bshumylo@gmail.com</authorEmail>
    <authorUrl>https://github.com/bshumylo</authorUrl>
    <creationDate>2026-07-19</creationDate>
    <copyright>(C) 2022-2025 Antonina Zdebska; (C) 2026 Bogdan Shumylo</copyright>
    <license>GNU General Public License version 3 or later; https://www.gnu.org/licenses/gpl-3.0</license>
    <version>2.0.1</version>
    <description>MOD_NEWSLETTER_SUBSCRIPTION_XML_DESCRIPTION</description>
    <namespace path="src">Zdebska\Module\NewsletterSubscription</namespace>
    <scriptfile>script.php</scriptfile>
    <files>
        <folder module="mod_newsletter_subscription">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
        <folder>css</folder>
        <folder>language</folder>
    </files>
    <languages>
        <language tag="en-GB">language/en-GB/mod_newsletter_subscription.ini</language>
        <language tag="en-GB">language/en-GB/mod_newsletter_subscription.sys.ini</language>
        <language tag="uk-UA">language/uk-UA/mod_newsletter_subscription.ini</language>
        <language tag="uk-UA">language/uk-UA/mod_newsletter_subscription.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="basic">
                <field name="email" type="radio" default="0" layout="joomla.form.field.radio.switcher"
                       label="MOD_NEWSLETTER_SUBSCRIPTION_FIELD_EMAIL_LABEL">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="tg" type="radio" default="0" layout="joomla.form.field.radio.switcher"
                       label="MOD_NEWSLETTER_SUBSCRIPTION_FIELD_TG_LABEL">
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field name="subject" type="text"
                       label="MOD_NEWSLETTER_SUBSCRIPTION_FIELD_SUBJECT_LABEL"
                       hint="MOD_NEWSLETTER_SUBSCRIPTION_FIELD_SUBJECT_HINT"/>
                <field name="message" type="textarea" rows="10" filter="safehtml"
                       label="MOD_NEWSLETTER_SUBSCRIPTION_FIELD_MESSAGE_LABEL"
                       hint="MOD_NEWSLETTER_SUBSCRIPTION_FIELD_MESSAGE_HINT"/>
                <field name="link" type="url" filter="url"
                       label="MOD_NEWSLETTER_SUBSCRIPTION_FIELD_LINK_LABEL"
                       hint="https://t.me/channel"/>
            </fieldset>
        </fields>
    </config>
</extension>
